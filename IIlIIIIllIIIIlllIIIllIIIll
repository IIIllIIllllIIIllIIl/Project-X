-- Priority: Main > Undercover > Possible
-- Returns "main", "undercover", or "possible" (or nil if none)
local function getPlayerCategory(inMain, isU, inPossible)
    if inMain then return "main" end
    if isU    then return "undercover" end
    if inPossible then return "possible" end
    return nil
end

local function applyESP(player)
    if not player or not player.Parent then return end

    local specialTag = SPECIAL_TAGS[player.UserId]
    if specialTag then
        local function updateDisplay()
            pcall(function()
                if player.Character and player.Character:FindFirstChild("Humanoid") then
                    player.Character.Humanoid.DisplayName = specialTag .. " " .. player.DisplayName
                end
            end)
        end
        player.CharacterAdded:Connect(function()
            task.wait(0.5)
            updateDisplay()
        end)
        if player.Character then updateDisplay() end
    end

    local mains      = getMainMemberships(player)
    local possible   = getPossibleMemberships(player)
    local inMain     = #mains > 0
    local inPossible = #possible > 0
    local isU        = isUndercover(player, inMain)
    local category   = getPlayerCategory(inMain, isU, inPossible)

    if not category then return end

    local function attach(char)
        if not char then return end
        local key, folder, fillClr, outlineClr
        if category == "main" then
            key    = "HL_"  .. player.UserId
            folder = state.StaffESPFolder
        elseif category == "undercover" then
            key    = "UHL_" .. player.UserId
            folder = state.UndercoverESPFolder
            fillClr    = Color3.fromRGB(255, 0, 0)
            outlineClr = Color3.fromRGB(255, 0, 0)
        else
            key    = "PHL_" .. player.UserId
            folder = state.PossibleESPFolder
            fillClr    = theme.PossibleStaff
            outlineClr = theme.PossibleStaff
        end
        local oldHl = folder:FindFirstChild(key)
        if oldHl then oldHl:Destroy() end
        local hl = Instance.new("Highlight", folder)
        hl.Name = key
        hl.Adornee = char
        hl.FillTransparency = 0.55
        hl.OutlineTransparency = 0.1
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Enabled = config.StaffESPEnabled
        if fillClr    then hl.FillColor    = fillClr    end
        if outlineClr then hl.OutlineColor = outlineClr end
    end

    if category == "main" then
        local title, body, color = buildNotif(player, "joined", mains, possible)
        notify(title, body, 5, nil, color)
        playSound("rbxassetid://8887499160", 2)
    elseif category == "undercover" then
        local dn = getDisplayName(player)
        local body = dn .. " (@" .. player.Name .. ") is here!"
        if inPossible then
            local parts = {}
            for _, m in ipairs(possible) do
                table.insert(parts, getGroupName(m.id) .. ": " .. m.role)
            end
            body = body .. " | Also in: " .. table.concat(parts, ", ")
        end
        notify("⚠ UNDERCOVER STAFF", body, 6, "warning")
        playSound("rbxassetid://8887499160", 2)
    else
        local title, body, _ = buildNotif(player, "joined", nil, possible)
        notify(title, body, 5, nil, theme.PossibleStaff)
        playSound("rbxassetid://8887499160", 2)
    end

    if player.Character then attach(player.Character) end
    player.CharacterAdded:Connect(attach)
end

local function onPlayerRemoving(player)
    local mains      = getMainMemberships(player)
    local possible   = getPossibleMemberships(player)
    local inMain     = #mains > 0
    local inPossible = #possible > 0
    local isU        = isUndercover(player, inMain)
    local category   = getPlayerCategory(inMain, isU, inPossible)

    if not category then return end
    playSound("rbxassetid://1091083826", 2)

    if category == "main" then
        local title, body, color = buildNotif(player, "left", mains, possible)
        notify(title, body, 5, nil, color)
        local hl = state.StaffESPFolder:FindFirstChild("HL_" .. player.UserId)
        if hl then hl:Destroy() end
    elseif category == "undercover" then
        local dn = getDisplayName(player)
        local body = dn .. " has left the server."
        if inPossible then
            local parts = {}
            for _, m in ipairs(possible) do
                table.insert(parts, getGroupName(m.id) .. ": " .. m.role)
            end
            body = body .. " | Was in: " .. table.concat(parts, ", ")
        end
        notify("UNDERCOVER PLAYER LEFT", body, 5, "warning")
        local hl = state.UndercoverESPFolder:FindFirstChild("UHL_" .. player.UserId)
        if hl then hl:Destroy() end
    else
        local title, body, _ = buildNotif(player, "left", nil, possible)
        notify(title, body, 5, nil, theme.PossibleStaff)
        local hl = state.PossibleESPFolder:FindFirstChild("PHL_" .. player.UserId)
        if hl then hl:Destroy() end
    end
end

-- Rainbow ESP: Heartbeat-driven for smooth, flicker-free colour cycling.
-- Hue is derived from elapsed wall-clock time so the animation stays
-- perfectly smooth regardless of frame rate or task-scheduler jitter.
local RAINBOW_SPEED = 0.4  -- full colour cycle per second (raise = faster)
do
    local _rainbowStart = tick()
    RunService.Heartbeat:Connect(function()
        local hue = (tick() - _rainbowStart) * RAINBOW_SPEED % 1
        local color = Color3.fromHSV(hue, 1, 1)
        for _, obj in ipairs(state.StaffESPFolder:GetChildren()) do
            if obj:IsA("Highlight") then
                obj.FillColor    = color
                obj.OutlineColor = color
            end
        end
    end)
end

