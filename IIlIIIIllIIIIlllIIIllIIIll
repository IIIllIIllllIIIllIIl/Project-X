-- F1 / Check Active Staff
-- F1 / Check Active Staff -- always fires regardless of NotificationsEnabled.
-- Results are shown in priority order: Main > Undercover > Possible Staff.
local function showStaffNotification()
    local mainLines, undLines, possLines = {}, {}, {}

    for _, p in ipairs(Players:GetPlayers()) do
        local mains      = getMainMemberships(p)
        local possible   = getPossibleMemberships(p)
        local inMain     = #mains > 0
        local inPossible = #possible > 0
        local isU        = isUndercover(p, inMain)
        local category   = getPlayerCategory(inMain, isU, inPossible)
        if not category then continue end

        local parts = {}
        for _, m in ipairs(mains) do
            table.insert(parts, getGroupName(m.id) .. ": " .. m.role)
        end
        if isU and not inMain then
            table.insert(parts, "[!] UNDERCOVER")
        end
        for _, m in ipairs(possible) do
            table.insert(parts, getGroupName(m.id) .. " (Possible Staff): " .. m.role)
        end
        local line = getDisplayName(p) .. " (@" .. p.Name .. ") | " .. table.concat(parts, " | ")

        if     category == "main"       then table.insert(mainLines, line)
        elseif category == "undercover" then table.insert(undLines,  line)
        else                                 table.insert(possLines, line)
        end
    end

    local allLines = {}
    for _, l in ipairs(mainLines) do table.insert(allLines, l) end
    for _, l in ipairs(undLines)  do table.insert(allLines, l) end
    for _, l in ipairs(possLines) do table.insert(allLines, l) end

    if #allLines > 0 then
        notify("STAFF IN SERVER", table.concat(allLines, "\n"), 8, "warning", nil, true)
    else
        notify("STAFF IN SERVER", "No staff or undercover players currently in the server.", 4, "success", nil, true)
    end
end

