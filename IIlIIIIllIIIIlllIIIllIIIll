    end
    pScroll.CanvasSize = UDim2.new(0, 0, 0, yPos)
end

local function ToggleAll(sel)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer then
            local data = PlayerCheckboxes[p.Name]
            if data then
                if sel then
                    SelectedTargets[p.Name] = p
                    data.Checkmark.Visible = true
                else
                    SelectedTargets[p.Name] = nil
                    data.Checkmark.Visible = false
                end
            end
        end
    end
    UpdateFlingStatus()
end

startFlingBtn.MouseButton1Click:Connect(function()
    if FlingActive then return end
    local c = CountSelectedTargets()
    if c == 0 then
        notify("FLING", "No targets selected!", 3, "warning")
        return
    end
    FlingActive = true
    UpdateFlingStatus()
    notify("FLING", "Started flinging " .. c .. " targets", 3, "success")
    task.spawn(function()
        while FlingActive do
            local valid = {}
            for name, p in pairs(SelectedTargets) do
                if p and p.Parent then valid[name] = p
                else
                    SelectedTargets[name] = nil
                    if PlayerCheckboxes[name] then PlayerCheckboxes[name].Checkmark.Visible = false end
                end
            end
            for _, p in pairs(valid) do
                if FlingActive then SkidFling(p) task.wait(0.1)
                else break end
            end
            UpdateFlingStatus()
            task.wait(0.5)
        end
    end)
end)

