-- Returns true if a player is relevant to the staff list.
-- Used so we only refresh the list when someone who matters joins or leaves.
local function isRelevantPlayer(p)
    if UNDERCOVER_USERIDS[p.UserId] then return true end
    for _, gid in ipairs(MAIN_GROUP_IDS) do
        local ok, inMain = pcall(function() return p:IsInGroup(gid) end)
        if ok and inMain then return true end
    end
    for _, gid in ipairs(POSSIBLE_STAFF_GROUP_IDS) do
        local ok2, inG = pcall(function() return p:IsInGroup(gid) end)
        if ok2 and inG then return true end
    end
    return false
end


