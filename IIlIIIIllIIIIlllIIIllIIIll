-- Group name cache — fetched live from Roblox, never hardcoded
local groupNameCache = {}
local function getGroupName(id)
    if groupNameCache[id] then return groupNameCache[id] end
    local ok, info = pcall(function() return GroupService:GetGroupInfoAsync(id) end)
    local name = (ok and info and info.Name) or ("Group " .. id)
    groupNameCache[id] = name
    return name
end

-- Pre-cache all group names at startup so they are ready instantly on first join/leave
task.spawn(function()
    local allIds = {}
    for _, id in ipairs(MAIN_GROUP_IDS) do table.insert(allIds, id) end
    for _, id in ipairs(POSSIBLE_STAFF_GROUP_IDS) do table.insert(allIds, id) end
    for _, id in ipairs(allIds) do
        pcall(function()
            local info = GroupService:GetGroupInfoAsync(id)
            if info and info.Name then groupNameCache[id] = info.Name end
        end)
    end
end)

