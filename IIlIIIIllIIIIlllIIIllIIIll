local function playSound(id, vol)
    if not config.SoundsEnabled then return end
    local s = Instance.new("Sound")
    s.SoundId = id
    s.Volume = vol or 2
    s.Parent = SoundService
    pcall(function() SoundService:PlayLocalSound(s) end)
    s.Ended:Connect(function() s:Destroy() end)
end

-- Returns a list of {id, role} for every main staff group the player is in
local function getMainMemberships(player)
    local result = {}
    for _, gid in ipairs(MAIN_GROUP_IDS) do
        local ok, inGroup = pcall(function() return player:IsInGroup(gid) end)
        if ok and inGroup then
            local ok2, role = pcall(function() return player:GetRoleInGroup(gid) end)
            table.insert(result, { id = gid, role = ok2 and role or "Member" })
        end
    end
    return result
end

-- Returns a list of {id, role} for every possible staff group the player is in
local function getPossibleMemberships(player)
    local result = {}
    for _, gid in ipairs(POSSIBLE_STAFF_GROUP_IDS) do
        local ok, inGroup = pcall(function() return player:IsInGroup(gid) end)
        if ok and inGroup then
            local ok2, role = pcall(function() return player:GetRoleInGroup(gid) end)
            table.insert(result, { id = gid, role = ok2 and role or "Member" })
        end
    end
    return result
end

local function isUndercover(player, alreadyInMain)
    if not UNDERCOVER_USERIDS[player.UserId] then return false end
    if alreadyInMain ~= nil then return not alreadyInMain end
    for _, gid in ipairs(MAIN_GROUP_IDS) do
        local ok, res = pcall(function() return player:IsInGroup(gid) end)
        if ok and res then return false end
    end
    return true
end

-- Builds the notifier title, body, and outline colour for a join/leave event
local function buildNotif(player, action, mains, possible)
    local dn = getDisplayName(player)
    local un = player.Name
    mains = mains or {}
    local inMain = #mains > 0
    local inPossible = #possible > 0
    local title, body, color

    if inMain and inPossible then
        -- Green (main has priority)
        color = theme.Success
        local names = {}
        for _, m in ipairs(mains)    do table.insert(names, getGroupName(m.id)) end
        for _, m in ipairs(possible) do table.insert(names, getGroupName(m.id)) end
        title = dn .. " | " .. table.concat(names, " & ")
        local parts = { dn .. " (@" .. un .. ")" }
        for _, m in ipairs(mains) do
            table.insert(parts, getGroupName(m.id) .. ": " .. m.role)
        end
        for _, m in ipairs(possible) do
            table.insert(parts, getGroupName(m.id) .. " (Possible Staff Group): " .. m.role)
        end
        body = table.concat(parts, " | ") .. " — " .. action

    elseif inMain then
        -- Main group only — green
        color = theme.Success
        local names = {}
        for _, m in ipairs(mains) do table.insert(names, getGroupName(m.id)) end
        title = dn .. " | " .. table.concat(names, " & ")
        local parts = { dn .. " (@" .. un .. ")" }
        for _, m in ipairs(mains) do
            table.insert(parts, getGroupName(m.id) .. ": " .. m.role)
        end
        body = table.concat(parts, " | ") .. " — " .. action

    elseif inPossible then
        -- Possible group(s) only — yellow
        color = theme.PossibleStaff
        local names = {}
        for _, m in ipairs(possible) do table.insert(names, getGroupName(m.id)) end
        title = dn .. " | " .. table.concat(names, " & ") .. " | Possible staff group"
        local parts = { dn .. " (@" .. un .. ")" }
        for _, m in ipairs(possible) do
            table.insert(parts, getGroupName(m.id) .. ": " .. m.role)
        end
        body = table.concat(parts, " | ") .. " — " .. action
    end

    return title, body, color
end

