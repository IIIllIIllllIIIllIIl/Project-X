-- Populate a section: add rows and update CanvasSize + counter header
local function slPopulate(entries, sf, emptyLbl, color, hdr, title)
    slClear(sf)
    emptyLbl.Visible = (#entries == 0)
    for i, e in ipairs(entries) do
        slAddRow(sf, i, e.display, e.detail, color)
