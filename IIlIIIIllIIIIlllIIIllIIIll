    local undEntries  = {}
    local possEntries = {}

    for _, p in ipairs(Players:GetPlayers()) do
        if p == localPlayer then continue end
        local mains      = getMainMemberships(p)
        local possible   = getPossibleMemberships(p)
        local inMain     = #mains > 0
        local inPossible = #possible > 0
        local isU        = isUndercover(p, inMain)
        local category   = getPlayerCategory(inMain, isU, inPossible)
        if not category then continue end

        local nameText = p.DisplayName .. " (@" .. p.Name .. ")"

        if inMain then
            local mainParts = {}
            for _, m in ipairs(mains) do table.insert(mainParts, getGroupName(m.id) .. ": " .. m.role) end
            local detail = table.concat(mainParts, "  |  ")
            if inPossible then
                local extras = {}
                for _, m in ipairs(possible) do table.insert(extras, getGroupName(m.id) .. ": " .. m.role) end
                detail = detail .. "  |  " .. table.concat(extras, "  |  ")
            end
            table.insert(mainEntries, { name = p.Name, display = nameText, detail = detail })
        end

        if isU and not inMain then
            local detail = "⚠ UNDERCOVER"
            if inPossible then
                local extras = {}
                for _, m in ipairs(possible) do table.insert(extras, getGroupName(m.id) .. ": " .. m.role) end
                detail = detail .. "  |  " .. table.concat(extras, "  |  ")
            end
            table.insert(undEntries, { name = p.Name, display = nameText, detail = detail })
        end

        if inPossible then
            local parts = {}
            for _, m in ipairs(possible) do table.insert(parts, getGroupName(m.id) .. ": " .. m.role) end
            table.insert(possEntries, { name = p.Name, display = nameText, detail = table.concat(parts, "  |  ") })
        end
    end

    local function sortAlpha(t) table.sort(t, function(a, b) return a.name:lower() < b.name:lower() end) end
    sortAlpha(mainEntries) sortAlpha(undEntries) sortAlpha(possEntries)
-- xx Subtitles staff list
    slPopulate(mainEntries, slMainSF, slMainEmpty, theme.Success,       slMainHdr, "— STAFF GROUP [MAIN]")
    slPopulate(undEntries,  slUndSF,  slUndEmpty,  theme.Warning,       slUndHdr,  "— UNDERCOVER STAFF [HIGH CHANCE]")
    slPopulate(possEntries, slPossSF, slPossEmpty, theme.PossibleStaff, slPossHdr, "— POSSIBLE STAFF GROUP [LOW CHANCE]")
end

