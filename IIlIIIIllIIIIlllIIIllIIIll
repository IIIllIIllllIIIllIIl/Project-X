    -- Set CanvasSize explicitly so the ScrollingFrame knows how tall the content is
    local totalH = #entries * SL_STRIDE + 12
    sf.CanvasSize = UDim2.new(1, 0, 0, totalH)
    hdr.Text = title .. " [" .. #entries .. "]"
end

