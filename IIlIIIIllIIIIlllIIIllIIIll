local function getBestMatch(txt)
    if txt == "" then return nil end
    txt = txt:lower()
    local matches = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #txt) == txt or p.DisplayName:lower():sub(1, #txt) == txt then
            table.insert(matches, p)
        end
    end
    if #matches == 0 then return nil end
    for _, p in ipairs(matches) do
        if p.Name:lower() == txt or p.DisplayName:lower() == txt then
            return p
        end
    end
    if #matches > 1 then
        table.sort(matches, function(a, b) return #a.Name < #b.Name end)
        if #matches[1].Name == #matches[2].Name then
            return nil
        end
    end
    return matches[1]
end

input:GetPropertyChangedSignal("Text"):Connect(function()
    local txt = input.Text
    local match = getBestMatch(txt)
    if match and txt ~= "" then
        local name = match.Name
        if name:lower():sub(1, #txt) == txt:lower() then
            suggestion.Text = txt .. name:sub(#txt + 1)
        else
            suggestion.Text = txt .. " (" .. match.DisplayName .. ")"
        end
    else
        suggestion.Text = ""
    end
end)

input.FocusLost:Connect(function(enter)
    if enter then
        local match = getBestMatch(input.Text)
        if match then
            input.Text = match.Name
            suggestion.Text = ""
        end
    end
end)

